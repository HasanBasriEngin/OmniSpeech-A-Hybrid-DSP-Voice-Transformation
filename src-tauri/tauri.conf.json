{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniSpeech",
  "version": "0.2.0",
  "identifier": "com.omnispeech.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OmniSpeech",
        "width": 1360,
        "height": 860,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"]
  }
}
