<UserControl x:Class="OmniSpeech_WPF.Controls.WaveformView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="88">
    <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" BorderBrush="#2B3246" BorderThickness="1">
        <Grid>
            <Canvas x:Name="WaveCanvas"/>
            <TextBlock Text="{Binding LabelText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{StaticResource Text3Brush}"
                       FontSize="10"
                       Margin="10,6,0,0"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"/>
        </Grid>
    </Border>
</UserControl>
