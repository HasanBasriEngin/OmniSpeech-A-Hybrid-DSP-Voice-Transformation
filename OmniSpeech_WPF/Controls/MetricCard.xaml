<UserControl x:Class="OmniSpeech_WPF.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="72">
    <Border Background="{StaticResource Bg2Brush}" CornerRadius="8" Padding="10,8" BorderBrush="#2B3246" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{StaticResource Text3Brush}"
                       FontSize="10"
                       FontWeight="SemiBold"/>
            <TextBlock Margin="0,4,0,0"
                       Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{Binding ValueBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="20"
                       FontWeight="Bold"/>
        </StackPanel>
    </Border>
</UserControl>
