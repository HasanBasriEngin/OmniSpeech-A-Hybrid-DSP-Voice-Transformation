<Application x:Class="OmniSpeech_WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="Bg0">#0D0F12</Color>
        <Color x:Key="Bg1">#141720</Color>
        <Color x:Key="Bg2">#1C2030</Color>
        <Color x:Key="Bg3">#232840</Color>
        <Color x:Key="Accent">#6C63FF</Color>
        <Color x:Key="Accent2">#A78BFA</Color>
        <Color x:Key="Teal">#22D3B0</Color>
        <Color x:Key="Amber">#F59E0B</Color>
        <Color x:Key="Red">#F87171</Color>
        <Color x:Key="Text1">#E8EAF0</Color>
        <Color x:Key="Text2">#8B92A8</Color>
        <Color x:Key="Text3">#565E78</Color>

        <SolidColorBrush x:Key="Bg0Brush" Color="{StaticResource Bg0}" />
        <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1}" />
        <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2}" />
        <SolidColorBrush x:Key="Bg3Brush" Color="{StaticResource Bg3}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2}" />
        <SolidColorBrush x:Key="TealBrush" Color="{StaticResource Teal}" />
        <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource Amber}" />
        <SolidColorBrush x:Key="Text1Brush" Color="{StaticResource Text1}" />
        <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource Text2}" />
        <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource Text3}" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource Bg0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style x:Key="PanelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
            <Setter Property="BorderBrush" Value="#2C3346" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Application.Resources>
</Application>
