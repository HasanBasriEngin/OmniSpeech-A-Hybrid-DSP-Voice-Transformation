<Window x:Class="OmniSpeech_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:OmniSpeech_WPF.Controls"
        xmlns:conv="clr-namespace:OmniSpeech_WPF.Converters"
        mc:Ignorable="d"
        Title="SpeechWarp"
        Height="900"
        Width="1520"
        MinHeight="700"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:PendingToBrushConverter x:Key="PendingToBrushConverter"/>

        <Style x:Key="SidebarItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Bg0Brush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{StaticResource Bg1Brush}" BorderBrush="#1F2534" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="8" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C63FF"/>
                                <GradientStop Color="#22D3B0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Margin="7">
                            <Path Stroke="White" StrokeThickness="1.6" StrokeLineJoin="Round" Data="M7,1 L7,13 M1,4 L7,1 L13,4 M1,10 L7,13 L13,10"/>
                        </Viewbox>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="SpeechWarp" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Text1Brush}"/>
                        <TextBlock Text="v0.9 · CENG 384" FontSize="10" Foreground="{StaticResource Text3Brush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource TealBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="ready" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,8,0"/>
                    <Border BorderBrush="#3A4156" BorderThickness="1" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                        <TextBlock Text="CPU · 12% load" Foreground="{StaticResource Text3Brush}" FontSize="10"/>
                    </Border>
                    <Border BorderBrush="#3A4156" BorderThickness="1" CornerRadius="4" Padding="8,3">
                        <TextBlock Text="Group 18" Foreground="{StaticResource Text3Brush}" FontSize="10"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource Bg1Brush}" BorderBrush="#1F2534" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,14">
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Border BorderBrush="#2A3042" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="3-STEP FLOW" Foreground="{StaticResource Text3Brush}" FontSize="10" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Load audio" Foreground="{StaticResource TealBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="2 Select module" Foreground="{StaticResource Accent2Brush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="3 Convert and export" Foreground="{StaticResource Text3Brush}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="NAVIGATION" Foreground="{StaticResource Text3Brush}" FontSize="10" Margin="8,0,0,8"/>
                    <Button Style="{StaticResource SidebarItemStyle}" Content="Workspace"/>

                    <TextBlock Text="DSP MODULES" Foreground="{StaticResource Text3Brush}" FontSize="10" Margin="8,10,0,8"/>
                    <Button Style="{StaticResource SidebarItemStyle}" Content="Emotion     FR10-15"/>
                    <Button Style="{StaticResource SidebarItemStyle}" Content="Gender / Age FR16-21"/>
                    <Button Style="{StaticResource SidebarItemStyle}" Content="Speaker      FR22-28"/>
                    <Button Style="{StaticResource SidebarItemStyle}" Content="Singing Voice FR29-33"/>

                    <TextBlock Text="SYSTEM" Foreground="{StaticResource Text3Brush}" FontSize="10" Margin="8,10,0,8"/>
                    <Button Style="{StaticResource SidebarItemStyle}" Content="Evaluation"/>
                    <Button Style="{StaticResource SidebarItemStyle}" Content="Settings"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Orientation="Vertical">
                <Border Background="{StaticResource Bg1Brush}" BorderBrush="#2A3042" BorderThickness="1" CornerRadius="12" Padding="14,14" Margin="0,0,0,14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="// audio_input" Foreground="{StaticResource Text3Brush}" FontSize="11" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <ToggleButton IsChecked="True" Content="FILE" Margin="0,0,6,0" Padding="10,4"/>
                                <ToggleButton Content="MIC" Padding="10,4"/>
                            </StackPanel>
                        </DockPanel>

                        <Border BorderThickness="1.5" BorderBrush="#4D586E" CornerRadius="10" Padding="16" Cursor="Hand" MouseLeftButtonUp="DropZone_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding LoadedFileName}" Foreground="{StaticResource Text1Brush}" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding LoadedFileMeta}" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <Border Background="{StaticResource Bg2Brush}" BorderBrush="#495267" BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="0,0,6,0"><TextBlock Text="WAV" FontSize="10" Foreground="{StaticResource Text3Brush}"/></Border>
                                    <Border Background="{StaticResource Bg2Brush}" BorderBrush="#495267" BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="0,0,6,0"><TextBlock Text="MP3" FontSize="10" Foreground="{StaticResource Text3Brush}"/></Border>
                                    <Border Background="{StaticResource Bg2Brush}" BorderBrush="#495267" BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="0,0,6,0"><TextBlock Text="FLAC" FontSize="10" Foreground="{StaticResource Text3Brush}"/></Border>
                                    <Border Background="{StaticResource Bg2Brush}" BorderBrush="#495267" BorderThickness="1" CornerRadius="4" Padding="8,2"><TextBlock Text="16kHz/22kHz" FontSize="10" Foreground="{StaticResource Text3Brush}"/></Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <controls:WaveformView x:Name="OriginalWaveView" LabelText="original" Seed="1.0" Amplitude="28" Margin="0,10,0,0"/>
                        <controls:WaveformView x:Name="ProcessedWaveView" LabelText="processed" Seed="2.4" Amplitude="22" Margin="0,6,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                            <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click" Width="32" Height="32" Content="▶"/>
                            <ProgressBar x:Name="PlaybackProgress" Minimum="0" Maximum="100" Value="34" Height="6" Margin="10,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TimeText" Text="0:01 / 0:02" Foreground="{StaticResource Text3Brush}" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource Bg1Brush}" BorderBrush="#2A3042" BorderThickness="1" CornerRadius="12" Padding="14,14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="// f0_pitch_contour" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,0,10"/>
                        <controls:PitchContourView/>
                    </StackPanel>
                </Border>

                <UniformGrid Columns="2" Margin="0,0,0,10">
                    <controls:MetricCard Label="LATENCY" Value="{Binding Latency}" ValueBrush="{StaticResource TealBrush}" Margin="0,0,6,6"/>
                    <controls:MetricCard Label="PROC TIME" Value="{Binding ProcTime}" ValueBrush="{StaticResource TealBrush}" Margin="6,0,0,6"/>
                    <controls:MetricCard Label="FIDELITY" Value="{Binding Fidelity}" Margin="0,6,6,0"/>
                    <controls:MetricCard Label="INTELLIG." Value="{Binding Intelligibility}" ValueBrush="{StaticResource TealBrush}" Margin="6,6,0,0"/>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <!-- Right panel -->
        <Border Grid.Row="1" Grid.Column="2" Background="{StaticResource Bg1Brush}" BorderBrush="#1F2534" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,16">
                    <TextBlock Text="// MODULE_SELECT" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,0,10"/>
                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <Button x:Name="EmotionModuleButton" Style="{StaticResource PanelButtonStyle}" Content="Emotion" Click="EmotionModuleButton_Click" Margin="0,0,6,6"/>
                        <Button x:Name="GenderModuleButton" Style="{StaticResource PanelButtonStyle}" Content="Gender/Age" Click="GenderModuleButton_Click" Margin="6,0,0,6"/>
                        <Button x:Name="SpeakerModuleButton" Style="{StaticResource PanelButtonStyle}" Content="Speaker" Click="SpeakerModuleButton_Click" Margin="0,6,6,0"/>
                        <Button x:Name="SingingModuleButton" Style="{StaticResource PanelButtonStyle}" Content="Singing" Click="SingingModuleButton_Click" Margin="6,6,0,0"/>
                    </UniformGrid>

                    <TextBlock Text="// PARAMETERS" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,0,10"/>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Pitch Ratio" Foreground="{StaticResource Text2Brush}" FontSize="11"/>
                            <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource Accent2Brush}" FontSize="11"
                                       Text="{Binding PitchRatio, StringFormat={}{0:+0.0;-0.0;0.0} st}"/>
                        </DockPanel>
                        <Slider Minimum="-6" Maximum="6" Value="{Binding PitchRatio}" SmallChange="0.1" TickFrequency="0.1" Margin="0,0,0,10"/>

                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Speech Rate" Foreground="{StaticResource Text2Brush}" FontSize="11"/>
                            <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource TealBrush}" FontSize="11"
                                       Text="{Binding SpeechRate, StringFormat={}{0:0.00}x}"/>
                        </DockPanel>
                        <Slider Minimum="0.6" Maximum="1.5" Value="{Binding SpeechRate}" SmallChange="0.01" TickFrequency="0.01" Margin="0,0,0,10"/>

                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Energy Envelope" Foreground="{StaticResource Text2Brush}" FontSize="11"/>
                            <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource AmberBrush}" FontSize="11"
                                       Text="{Binding EnergyEnvelope, StringFormat={}{0:0.00}x}"/>
                        </DockPanel>
                        <Slider Minimum="0.2" Maximum="2.0" Value="{Binding EnergyEnvelope}" SmallChange="0.05" TickFrequency="0.05" Margin="0,0,0,12"/>
                    </StackPanel>

                    <TextBlock Text="// TARGET_EMOTION" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,14">
                        <Button Content="sad" Click="EmotionChip_Click" Tag="sad" Margin="0,0,6,6" Padding="10,3"/>
                        <Button Content="angry" Click="EmotionChip_Click" Tag="angry" Margin="0,0,6,6" Padding="10,3"/>
                        <Button Content="excited" Click="EmotionChip_Click" Tag="excited" Margin="0,0,6,6" Padding="10,3"/>
                        <Button Content="whisper" Click="EmotionChip_Click" Tag="whisper" Margin="0,0,6,6" Padding="10,3"/>
                        <Button Content="calm" Click="EmotionChip_Click" Tag="calm" Margin="0,0,6,6" Padding="10,3"/>
                    </WrapPanel>

                    <Button x:Name="ConvertButton" Height="44" Click="ConvertButton_Click" Foreground="White" FontWeight="SemiBold" Content="▶ Convert Audio" Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C63FF"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                    <TextBlock Text="// SESSION_LOG" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,14,0,8"/>
                    <Border BorderBrush="#2A3042" BorderThickness="1" CornerRadius="8" Padding="8" Background="{StaticResource Bg2Brush}">
                        <ScrollViewer Height="210" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SessionLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <Ellipse Width="6" Height="6"
                                                     Fill="{Binding Pending, Converter={StaticResource PendingToBrushConverter}}"
                                                     Margin="0,4,8,0"/>
                                            <TextBlock Text="{Binding Time}" Foreground="{StaticResource Text3Brush}" FontSize="10" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource Text2Brush}" FontSize="11" TextWrapping="Wrap"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
